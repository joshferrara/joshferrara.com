---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BackgroundSwitcher from '../components/BackgroundSwitcher.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  wide?: boolean;
}

const { title, description, image, wide = false } = Astro.props;
---

<!doctype html>
<html lang="en" data-bg="vignette">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <script is:inline>
      (function () {
        try {
          var v = localStorage.getItem('bg-variant');
          if (v && ['vignette', 'aurora', 'sunrise', 'wash', 'forest', 'dots', 'grain'].indexOf(v) !== -1) {
            document.documentElement.setAttribute('data-bg', v);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main class:list={['main', 'container', { 'container--wide': wide }]}>
      <slot />
    </main>
    <Footer />
    <BackgroundSwitcher />
  </body>
</html>

<style>
  .main {
    padding-top: var(--space-10);
    padding-bottom: var(--space-16);
  }
</style>
