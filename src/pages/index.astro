---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcons from '../components/SocialIcons.astro';
import HomepageSection from '../components/HomepageSection.astro';
import PostCard from '../components/PostCard.astro';
import TweetCard from '../components/TweetCard.astro';
import allTweets from '../data/tweets.json';
import { getTopArtists } from '../lib/lastfm';
import { getRecentFilms } from '../lib/letterboxd';
import { getReadBooks } from '../lib/hardcover';

const writing = (await getCollection('writing'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((post) => {
    // Extract first ~150 chars of plain text from body as excerpt
    const plain = post.body
      ?.replace(/^---[\s\S]*?---/, '')  // strip frontmatter
      .replace(/>\s*[^\n]+/g, '')        // strip blockquotes
      .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // markdown links → text
      .replace(/[#*_`~\[\]]/g, '')       // strip markdown syntax
      .replace(/\n+/g, ' ')
      .trim() || '';
    const excerpt = plain.length > 150 ? plain.slice(0, 150).replace(/\s+\S*$/, '') + '...' : plain;
    return { ...post, excerpt };
  });

const recentTweets = (allTweets as any[])
  .filter((t) => !t.isRetweet && !t.isReply)
  .slice(0, 5);

const topArtists = await getTopArtists('7day', 6);
const recentFilms = await getRecentFilms(6);
const recentBooks = await getReadBooks(6);
---

<BaseLayout title="Home" wide>
  <!-- SVG Filters -->
  <svg class="sr-only" aria-hidden="true">
    <defs>
      <filter id="ink-settle" x="-15%" y="-15%" width="130%" height="130%" color-interpolation-filters="sRGB">
        <feTurbulence id="ink-turbulence" type="fractalNoise" baseFrequency="0.04 0.03" numOctaves="3" seed="5" result="noise" />
        <feDisplacementMap id="ink-displacement" in="SourceGraphic" in2="noise" scale="0" xChannelSelector="R" yChannelSelector="G" result="displaced" />
        <feGaussianBlur id="ink-blur" in="displaced" stdDeviation="0" />
      </filter>
    </defs>
  </svg>

  <!-- Bio Section -->
  <header class="bio animate-in animate-in-1">
    <div class="bio__photo-wrap">
      <img src="/images/josh.jpg" alt="Josh Ferrara" class="bio__photo" width="200" height="200" />
    </div>
    <div class="bio__text">
      <h1 class="bio__name">Josh Ferrara</h1>
      <span class="bio__accent" aria-hidden="true"></span>
      <p class="bio__tagline">Product strategy, AI, family.</p>
      <p class="bio__location">
        <svg class="bio__icon" viewBox="0 0 384 512" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"/></svg>
        Baton Rouge, Louisiana
      </p>
      <SocialIcons class="bio__socials" />
    </div>
  </header>

  <hr class="animate-in animate-in-2" />

  <!-- Content Grid -->
  <div class="content-grid">
    <!-- Left column: Writing + Tweets -->
    <div class="content-grid__left">
      <div class="animate-in animate-in-3" data-section="writing">
        <HomepageSection title="Latest Writing" href="/writing/">
          {writing.map((post) => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              description={post.excerpt}
              href={`/writing/${post.id}/`}
            />
          ))}
        </HomepageSection>
      </div>

      <div class="animate-in animate-in-5" data-section="tweets">
        <HomepageSection title="Recent Tweets" href="/tweets/" linkText="More on X">
          <div class="tweet-list">
            {recentTweets.map((tweet: any) => (
              <TweetCard
                id={tweet.id}
                text={tweet.text}
                date={tweet.date}
                compact
              />
            ))}
          </div>
        </HomepageSection>
      </div>
    </div>

    <!-- Right column: All media -->
    <div class="content-grid__right">
      <div class="animate-in animate-in-4" data-section="listening">
        <HomepageSection title="Listening To" href="/listening/" linkText="Full history">
          {topArtists.length > 0 ? (
            <div class="media-row">
              {topArtists.map((artist) => (
                <a href={artist.url} target="_blank" rel="noopener noreferrer" class="media-card">
                  {artist.image ? (
                    <img src={artist.image} alt={artist.name} class="media-card__img media-card__img--square" loading="lazy" />
                  ) : (
                    <div class="media-card__fallback media-card__img--square">{artist.name}</div>
                  )}
                  <span class="media-card__title">{artist.name}</span>
                  <span class="media-card__subtitle">{artist.playcount} plays</span>
                </a>
              ))}
            </div>
          ) : (
            <p class="placeholder-text">Last.fm data will appear here once connected.</p>
          )}
        </HomepageSection>
      </div>

      <div class="animate-in animate-in-4" data-section="watching">
        <HomepageSection title="Recently Watched" href="/watching/" linkText="Full diary">
          {recentFilms.length > 0 ? (
            <div class="media-row">
              {recentFilms.map((film) => (
                <a href={film.link} target="_blank" rel="noopener noreferrer" class="media-card">
                  {film.image ? (
                    <img src={film.image} alt={film.title} class="media-card__img media-card__img--portrait" loading="lazy" />
                  ) : (
                    <div class="media-card__fallback media-card__img--portrait">{film.title}</div>
                  )}
                  <span class="media-card__title">{film.title}</span>
                  {film.year && <span class="media-card__subtitle">{film.year}</span>}
                </a>
              ))}
            </div>
          ) : (
            <p class="placeholder-text">Letterboxd data will appear here once connected.</p>
          )}
        </HomepageSection>
      </div>

      <div class="animate-in animate-in-4" data-section="reading">
        <HomepageSection title="Recently Read" href="/library/">
          {recentBooks.length > 0 ? (
            <div class="media-row">
              {recentBooks.map((book) => (
                <a href={`https://hardcover.app/books/${book.slug}`} target="_blank" rel="noopener noreferrer" class="media-card">
                  {book.coverUrl ? (
                    <img src={book.coverUrl} alt={book.title} class="media-card__img media-card__img--portrait" loading="lazy" />
                  ) : (
                    <div class="media-card__fallback media-card__img--portrait">{book.title}</div>
                  )}
                  <span class="media-card__title">{book.title}</span>
                  <span class="media-card__subtitle">{book.author}</span>
                </a>
              ))}
            </div>
          ) : (
            <p class="placeholder-text">Hardcover data will appear here once connected.</p>
          )}
        </HomepageSection>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero: Living Ink ────────────────────────────── */

  /* Bio */
  .bio {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-10);
    margin-bottom: var(--space-16);
  }

  /* Floating photo */
  .bio__photo-wrap {
    position: relative;
    z-index: 1;
    animation: photo-float 8s ease-in-out infinite;
  }

  @keyframes photo-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25%      { transform: translateY(-3px) rotate(0.3deg); }
    50%      { transform: translateY(-5px) rotate(0deg); }
    75%      { transform: translateY(-2px) rotate(-0.3deg); }
  }

  .bio__photo {
    width: 200px;
    height: 200px;
    border-radius: 44px;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: var(--shadow-xl);
    border: 4px solid var(--color-bg-raised);
    outline: 3px solid var(--color-accent);
  }

  .bio__text {
    position: relative;
    z-index: 1;
  }

  /* Ink-settle filter on the name */
  .bio__name {
    font-size: clamp(3.5rem, 3rem + 3vw, 6rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0;
    filter: url(#ink-settle);
    will-change: filter;
  }

  /* Breathing accent line */
  .bio__accent {
    display: block;
    width: 48px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
    margin-top: var(--space-6);
    margin-bottom: 0;
    animation: accent-breathe 5s ease-in-out infinite;
    transform-origin: left center;
  }

  @keyframes accent-breathe {
    0%, 100% { transform: scaleX(1); opacity: 1; }
    50%      { transform: scaleX(1.25); opacity: 0.7; }
  }

  .bio__tagline {
    font-size: var(--text-3xl);
    color: var(--color-text);
    margin-bottom: var(--space-2);
    font-family: var(--font-serif);
    font-style: italic;
  }

  .bio__location {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .bio__icon {
    display: inline-block;
    vertical-align: -0.1em;
    opacity: 0.4;
    margin-right: var(--space-1);
  }

  /* ── Reduced motion ────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .bio__photo-wrap { animation: none; }
    .bio__accent { animation: none; }
    .bio__name { filter: none; }
  }

  /* ── Content Grid ──────────────────────────────── */
  .content-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-8);
    align-items: start;
  }

  .content-grid__left,
  .content-grid__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .tweet-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .placeholder-text {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-style: italic;
  }

  /* Shared media grid (artists, films, books) */
  .media-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5) var(--space-4);
  }

  .media-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .media-card__img {
    width: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .media-card__img--portrait { aspect-ratio: 2/3; }
  .media-card__img--square { aspect-ratio: 1; border-radius: var(--radius-lg); }

  .media-card:hover .media-card__img {
    transform: translateY(-4px) scale(1.03);
    box-shadow: var(--shadow-xl);
  }

  .media-card__fallback {
    width: 100%;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: center;
    padding: var(--space-2);
  }

  .media-card__title {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-heading);
    line-height: var(--leading-snug);
  }

  .media-card__subtitle {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    /* Writing + Tweets first, then media */
    .content-grid__left { order: 1; }
    .content-grid__right { order: 2; }
  }

  @media (max-width: 480px) {
    .bio {
      flex-direction: column;
      text-align: center;
    }

    .bio__photo {
      width: 104px;
      height: 104px;
      border-radius: 23px;
    }

    .bio__accent {
      margin-inline: auto;
    }

    .bio :global(.social-icons) {
      justify-content: center;
    }
  }
</style>

<script>
  // Living Ink: animate displacement + blur on the name heading.
  // On load, text appears organically distorted (like wet ink on paper)
  // then settles into crisp text with a barely perceptible organic breathing.
  (function inkSettle() {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion) return;

    const displacement = document.getElementById('ink-displacement');
    const blur = document.getElementById('ink-blur');
    if (!displacement) return;

    // Displacement: how much the noise distorts the text
    const dispStart = 30;
    const dispSettled = 0.5;
    // Blur: text starts slightly soft (wet ink) and dries sharp
    const blurStart = 1.8;
    const blurSettled = 0;
    // Timing
    const settleDuration = 2400;
    const breatheAmplitude = 0.3;
    const breathePeriod = 8000;
    const startTime = performance.now();

    function easeOutExpo(t: number): number {
      return t >= 1 ? 1 : 1 - Math.pow(2, -10 * t);
    }

    displacement.setAttribute('scale', String(dispStart));
    if (blur) blur.setAttribute('stdDeviation', String(blurStart));

    let settled = false;

    function tick(now: number) {
      const elapsed = now - startTime;

      if (!settled) {
        const progress = Math.min(elapsed / settleDuration, 1);
        const eased = easeOutExpo(progress);

        const scale = dispStart + (dispSettled - dispStart) * eased;
        displacement.setAttribute('scale', String(scale));

        if (blur) {
          const b = blurStart + (blurSettled - blurStart) * eased;
          blur.setAttribute('stdDeviation', String(Math.max(0, b)));
        }

        if (progress >= 1) settled = true;
      } else {
        // Subtle breathing — barely perceptible organic wavering
        const breatheElapsed = elapsed - settleDuration;
        const t = (breatheElapsed % breathePeriod) / breathePeriod;
        const scale = dispSettled + Math.sin(t * Math.PI * 2) * breatheAmplitude;
        displacement.setAttribute('scale', String(Math.max(0, scale)));
      }

      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  })();
</script>
