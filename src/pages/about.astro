---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcons from '../components/SocialIcons.astro';
---

<BaseLayout
  title="About"
  description="About Josh Ferrara — product strategist, dad, musician, reader, photographer."
>
  <header class="about-header">
    <div class="about-photo-placeholder" aria-label="Photo of Josh Ferrara">JF</div>
    <h1>About</h1>
  </header>

  <div class="prose">
    <p class="lede">
      I'm Josh Ferrara — a product strategist based in [location]. I spend my
      days thinking about how technology shapes the way people live, work, and
      connect.
    </p>

    <h2>A little context</h2>
    <p>
      [This section will cover what drives Josh professionally — product
      strategy, the intersection of technology and human experience, and how
      various interests (music, photography, reading, food) inform a more
      textured approach to building things.]
    </p>

    <h2>Career</h2>
    <div class="timeline">
      <div class="timeline__item">
        <div class="timeline__date">2023 &ndash; Present</div>
        <div class="timeline__content">
          <h3>[Current Role]</h3>
          <p class="timeline__company">[Company]</p>
          <p>[Brief description of role and responsibilities.]</p>
        </div>
      </div>

      <div class="timeline__item">
        <div class="timeline__date">2020 &ndash; 2023</div>
        <div class="timeline__content">
          <h3>[Previous Role]</h3>
          <p class="timeline__company">[Company]</p>
          <p>[Brief description.]</p>
        </div>
      </div>

      <div class="timeline__item">
        <div class="timeline__date">2017 &ndash; 2020</div>
        <div class="timeline__content">
          <h3>[Earlier Role]</h3>
          <p class="timeline__company">[Company]</p>
          <p>[Brief description.]</p>
        </div>
      </div>
    </div>

    <h2>Background</h2>
    <p>
      [Personal history — LSU, path into tech/product, how music and
      photography and reading all connect, the thread that ties everything
      together.]
    </p>

    <h2>Elsewhere</h2>
    <SocialIcons />
  </div>
</BaseLayout>

<style>
  .about-header {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .about-photo-placeholder {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--color-bg-subtle);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .prose h2 {
    font-size: var(--text-2xl);
    margin-top: var(--space-6);
  }

  .lede {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-heading);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
  }

  .timeline__date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-top: var(--space-1);
    white-space: nowrap;
  }

  .timeline__content h3 {
    font-size: var(--text-lg);
    font-family: var(--font-sans);
    margin-bottom: var(--space-1);
  }

  .timeline__company {
    font-size: var(--text-sm);
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .timeline__content p:last-child {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 480px) {
    .about-header {
      flex-direction: column;
      text-align: center;
    }

    .timeline__item {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
