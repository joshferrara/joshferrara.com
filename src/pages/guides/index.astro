---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export const prerender = true;

const allGuides = await getCollection('guides');
const guides = allGuides
  .filter((g) => !g.id.startsWith('_'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Guides" description="How-to and reference content by Josh Ferrara.">
  <h1>Guides</h1>
  <p class="page-description">How-to and reference content — packing lists, photo organization, and more.</p>

  {guides.length === 0 ? (
    <p class="empty-state">No guides yet. Check back soon.</p>
  ) : (
    <div class="guides-list">
      {guides.map((guide) => (
        <PostCard
          title={guide.data.title}
          date={guide.data.date}
          description={guide.data.description}
          tags={guide.data.tags}
          growthStage={guide.data.growthStage}
          href={`/guides/${guide.id}/`}
        />
      ))}
    </div>
  )}
</BaseLayout>

<style>
  h1 { margin-bottom: var(--space-2); }
  .page-description { color: var(--color-text-muted); margin-bottom: var(--space-8); }
  .empty-state { color: var(--color-text-muted); font-style: italic; }
  .guides-list { display: flex; flex-direction: column; }
</style>
