---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <div class="not-found">
    <h1>404</h1>
    <p>This page doesn't exist — maybe it moved, maybe it never did.</p>
    <nav class="not-found__links">
      <a href="/">Go home</a>
      <a href="/search/">Search the site</a>
      <a href="/writing/">Read something</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: var(--space-16) 0;
  }

  .not-found h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    color: var(--color-border);
    line-height: 1;
    margin-bottom: var(--space-4);
  }

  .not-found p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
    max-width: none;
  }

  .not-found__links {
    display: flex;
    gap: var(--space-6);
    justify-content: center;
    flex-wrap: wrap;
  }

  .not-found__links a {
    font-size: var(--text-sm);
  }
</style>
