---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TweetCard from '../../components/TweetCard.astro';
import allTweets from '../../data/tweets.json';

export const prerender = true;

// Filter: show original tweets (no retweets), include replies
const tweets = allTweets.filter((t: any) => !t.isRetweet);
const PER_PAGE = 50;
const totalPages = Math.ceil(tweets.length / PER_PAGE);
const page = 1;
const pageTweets = tweets.slice(0, PER_PAGE);
---

<BaseLayout title="Tweets" description="Josh Ferrara's tweet archive — 7,500+ tweets from 2007 to 2026.">
  <h1>Tweets</h1>
  <p class="page-description">
    {tweets.length.toLocaleString()} tweets from the archive (2007–2026).
    Replies are dimmed.
  </p>

  <div class="tweets-list">
    {pageTweets.map((tweet: any) => (
      <TweetCard
        id={tweet.id}
        text={tweet.text}
        date={tweet.date}
        isReply={tweet.isReply}
      />
    ))}
  </div>

  {totalPages > 1 && (
    <nav class="pagination" aria-label="Tweet pages">
      <span class="pagination__current">Page {page} of {totalPages}</span>
      <a href="/tweets/2/" class="pagination__next">Older &rarr;</a>
    </nav>
  )}
</BaseLayout>

<style>
  h1 { margin-bottom: var(--space-2); }
  .page-description { color: var(--color-text-muted); margin-bottom: var(--space-6); }
  .tweets-list { display: flex; flex-direction: column; }

  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-subtle);
  }

  .pagination__current {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .pagination__next, .pagination__prev {
    font-size: var(--text-sm);
  }
</style>
