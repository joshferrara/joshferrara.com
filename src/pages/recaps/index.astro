---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

const allRecaps = await getCollection('recaps');
const recaps = allRecaps.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Annual Recaps" description="Year-in-review posts — books, music, food, moments, and more.">
  <h1>Annual Recaps</h1>
  <p class="page-description">A year-by-year look back at the things I loved.</p>

  <div class="recaps-grid">
    {recaps.map((recap) => (
      <a href={`/recaps/${recap.data.year}/`} class="recap-card card">
        <span class="recap-card__year">{recap.data.year}</span>
        <h3 class="recap-card__title">{recap.data.title}</h3>
        {recap.data.description && (
          <p class="recap-card__description">{recap.data.description}</p>
        )}
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  h1 { margin-bottom: var(--space-2); }
  .page-description { color: var(--color-text-muted); margin-bottom: var(--space-8); }

  .recaps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .recap-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .recap-card__year {
    font-size: var(--text-4xl);
    font-family: var(--font-serif);
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .recap-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--color-text-heading);
    transition: color var(--transition-fast);
  }

  .recap-card:hover .recap-card__title { color: var(--color-accent); }

  .recap-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
