---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

const allRecaps = await getCollection('recaps');
const recaps = allRecaps.sort((a, b) => b.data.year - a.data.year);

// The big numeral already carries the year — strip it from the title so the
// row doesn't say "2025" twice ("Things I Loved In 2025" -> "Things I Loved").
const cleanTitle = (title: string) =>
  title.replace(/\s*\bin\s+\d{4}\b\s*$/i, '').replace(/\s*\d{4}\s*$/, '').trim();
---

<BaseLayout title="Annual Recaps" description="Year-in-review posts — books, music, food, moments, and more.">
  <h1>Annual Recaps</h1>
  <p class="page-description">A year-by-year look back at the things I loved.</p>

  <ol class="recaps-list" role="list">
    {recaps.map((recap) => (
      <li>
        <a href={`/recaps/${recap.data.year}/`} class="recap-row">
          <span class="recap-row__year">{recap.data.year}</span>
          <span class="recap-row__body">
            <span class="recap-row__title">{cleanTitle(recap.data.title)}</span>
            <span class="recap-row__description">Moments, meals, books, music, film &amp; more.</span>
          </span>
          <span class="recap-row__cue" aria-hidden="true">&rarr;</span>
        </a>
      </li>
    ))}
  </ol>
</BaseLayout>

<style>
  h1 { margin-bottom: var(--space-2); }
  .page-description { color: var(--color-text-muted); margin-bottom: var(--space-8); }

  .recaps-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .recaps-list li + li {
    border-top: 1px solid var(--color-border-subtle);
  }

  .recap-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    column-gap: var(--space-6);
    padding: var(--space-6) 0;
    text-decoration: none;
    color: inherit;
  }

  /* The big warm numeral is the design element — the tan secondary accent
     finally earns its keep here. */
  .recap-row__year {
    font-family: var(--font-serif);
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 0.9;
    color: var(--color-warm);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
    transition: color var(--transition-fast);
  }

  .recap-row__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .recap-row__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-text-heading);
    letter-spacing: -0.02em;
    transition: color var(--transition-fast);
  }

  .recap-row__description {
    font-family: var(--font-serif-text);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    max-width: 52ch;
  }

  .recap-row__cue {
    align-self: center;
    color: var(--color-accent);
    font-size: var(--text-lg);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .recap-row:hover .recap-row__year { color: var(--color-accent); }
  .recap-row:hover .recap-row__title { color: var(--color-accent); }
  .recap-row:hover .recap-row__cue,
  .recap-row:focus-visible .recap-row__cue {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .recap-row__cue { transition: opacity var(--transition-fast); transform: none; }
  }

  @media (max-width: 480px) {
    .recap-row {
      column-gap: var(--space-4);
      padding: var(--space-5) 0;
    }
    .recap-row__year { font-size: var(--text-4xl); }
    .recap-row__cue { display: none; }
  }
</style>
