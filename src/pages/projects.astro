---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

export const prerender = true;

// Map a project slug -> optimized cover in src/assets/projects/<slug>.*
const covers = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/projects/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
);
const coverFor = (id: string) => {
  const hit = Object.entries(covers).find(
    ([path]) => path.split('/').pop()!.replace(/\.[^.]+$/, '') === id,
  );
  return hit?.[1].default;
};

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const active = projects.filter((p) => p.data.status === 'active');
const archived = projects.filter((p) => p.data.status === 'archived');

const categories = [
  { key: 'products', label: 'Products' },
  { key: 'open-source', label: 'Open Source' },
  { key: 'fun', label: 'Just For Fun' },
] as const;
const sections = categories
  .map((c) => ({ ...c, projects: active.filter((p) => p.data.category === c.key) }))
  .filter((c) => c.projects.length > 0);
---

<BaseLayout title="Projects" description="Side projects, tools, and things Josh Ferrara has built." full>
  <h1>Projects</h1>
  <p class="page-description">Things I've built, big and small.</p>

  {sections.map(({ label, projects: sectionProjects }) => (
    <>
      <h2 class="section-label">{label}</h2>
      <div class="project-grid">
        {sectionProjects.map((project) => (
          <ProjectCard project={project} cover={coverFor(project.id)} />
        ))}
      </div>
    </>
  ))}

  {archived.length > 0 && (
    <>
      <h2 class="section-label">Archived</h2>
      <div class="project-grid">
        {archived.map((project) => (
          <ProjectCard project={project} cover={coverFor(project.id)} archived />
        ))}
      </div>
    </>
  )}

  <hr />
  <p class="recaps-link">
    <a href="/recaps/">Annual Recaps &rarr;</a>
  </p>
</BaseLayout>

<style>
  h1 {
    margin-bottom: var(--space-2);
  }

  .page-description {
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .section-label {
    font-size: var(--text-lg);
    font-family: var(--font-sans);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .recaps-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
