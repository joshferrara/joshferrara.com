---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTopArtists, getRecentTracks } from '../lib/lastfm';

export const prerender = true;

const topArtistsMonth = await getTopArtists('1month', 10);
const topArtistsYear = await getTopArtists('12month', 10);
const recentTracks = await getRecentTracks(20);
const hasData = topArtistsMonth.length > 0 || recentTracks.length > 0;
---

<BaseLayout title="Listening" description="What Josh Ferrara has been listening to, powered by Last.fm." wide>
  <h1>Listening</h1>
  <p class="page-description">What I've been listening to, tracked via <a href="https://last.fm/user/joshferrara" target="_blank" rel="noopener noreferrer">Last.fm</a>.</p>

  {!hasData ? (
    <div class="empty-state">
      <p>Last.fm data isn't available yet. Set <code>LASTFM_API_KEY</code> and <code>LASTFM_USERNAME</code> environment variables to enable this page.</p>
    </div>
  ) : (
    <>
      {topArtistsMonth.length > 0 && (
        <section class="listening-section">
          <div class="section-heading">
            <h2>Top Artists &middot; Month</h2>
            <span class="section-meta">last 30 days</span>
          </div>
          <div class="artist-grid">
            {topArtistsMonth.map((artist, i) => (
              <a href={artist.url} target="_blank" rel="noopener noreferrer" class="artist-card">
                <div class="artist-card__art">
                  {artist.image ? (
                    <img src={artist.image} alt="" class="artist-card__img" loading="lazy" />
                  ) : (
                    <div class="artist-card__placeholder">{artist.name.charAt(0)}</div>
                  )}
                  <span class="artist-card__rank">{i + 1}</span>
                </div>
                <span class="artist-card__name">{artist.name}</span>
                <span class="artist-card__plays">{artist.playcount} plays</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {topArtistsYear.length > 0 && (
        <section class="listening-section">
          <div class="section-heading">
            <h2>Top Artists &middot; Year</h2>
            <span class="section-meta">last 12 months</span>
          </div>
          <div class="artist-grid">
            {topArtistsYear.map((artist, i) => (
              <a href={artist.url} target="_blank" rel="noopener noreferrer" class="artist-card">
                <div class="artist-card__art">
                  {artist.image ? (
                    <img src={artist.image} alt="" class="artist-card__img" loading="lazy" />
                  ) : (
                    <div class="artist-card__placeholder">{artist.name.charAt(0)}</div>
                  )}
                  <span class="artist-card__rank">{i + 1}</span>
                </div>
                <span class="artist-card__name">{artist.name}</span>
                <span class="artist-card__plays">{artist.playcount} plays</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {recentTracks.length > 0 && (
        <section class="listening-section">
          <div class="section-heading">
            <h2>Recent Tracks</h2>
            <span class="section-meta">{recentTracks.length} latest</span>
          </div>
          <div class="tracks-list">
            {recentTracks.map((track) => (
              <a href={track.url} target="_blank" rel="noopener noreferrer" class="track-item">
                {track.image ? (
                  <img src={track.image} alt="" class="track-item__img" loading="lazy" />
                ) : (
                  <div class="track-item__img track-item__img--placeholder">{track.name.charAt(0)}</div>
                )}
                <div class="track-item__info">
                  <span class="track-item__name">
                    {track.nowPlaying && <span class="now-playing">▶</span>}
                    {track.name}
                  </span>
                  <span class="track-item__artist">{track.artist}</span>
                </div>
                {track.date && <time class="track-item__date">{track.date}</time>}
              </a>
            ))}
          </div>
        </section>
      )}
    </>
  )}
</BaseLayout>

<style>
  h1 { margin-bottom: var(--space-2); }
  .page-description { color: var(--color-text-muted); margin-bottom: var(--space-10); }
  .page-description a { color: var(--color-accent); }
  .empty-state { color: var(--color-text-muted); }
  .empty-state code { font-size: var(--text-sm); }

  .listening-section { margin-bottom: var(--space-12); }
  .listening-section:last-child { margin-bottom: 0; }

  /* Compact small-caps header, with a muted qualifier on the right.
     Reuses the global .section-heading (accent underline + small-caps green h2). */
  .section-meta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  /* --- Top artists: responsive tile grid (mirrors the Watching page) --- */
  .artist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--space-5) var(--space-4);
  }
  .artist-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    text-decoration: none;
    color: inherit;
  }
  .artist-card__art {
    position: relative;
    aspect-ratio: 1;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-subtle);
  }
  .artist-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }
  .artist-card:hover .artist-card__img { transform: scale(1.03); }
  .artist-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-text-muted);
  }
  .artist-card__rank {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(21, 21, 22, 0.55);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-sm);
    font-variant-numeric: tabular-nums;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
    -webkit-backdrop-filter: blur(2px);
    backdrop-filter: blur(2px);
  }
  .artist-card__name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .artist-card__plays { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: -2px; }

  /* --- Recent tracks: compact two-column list --- */
  .tracks-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--space-8);
  }
  .track-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border-subtle);
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }
  .track-item__img {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    flex: none;
    object-fit: cover;
  }
  .track-item__img--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-subtle);
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .track-item__info { flex: 1; min-width: 0; }
  .track-item__name { display: block; font-size: var(--text-sm); color: var(--color-text-heading); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .track-item__artist { font-size: var(--text-xs); color: var(--color-text-muted); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .track-item__date { font-size: var(--text-xs); color: var(--color-text-muted); white-space: nowrap; }
  .now-playing { color: var(--color-accent); margin-right: var(--space-1); }

  @media (max-width: 640px) {
    .tracks-list { grid-template-columns: 1fr; column-gap: 0; }
  }
</style>
