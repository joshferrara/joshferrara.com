---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import DraftBanner from '../../components/DraftBanner.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: sorted[index + 1] ?? null,
      nextPost: sorted[index - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description} wide>
  <article class="post">
    <header class="post__header">
      <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
      <h1>{post.data.title}</h1>
      {post.data.description && (
        <p class="post__description">{post.data.description}</p>
      )}
      {post.data.tags.length > 0 && (
        <div class="post__tags" aria-label="Topics">
          <span class="post__tags-label">Filed under</span>
          <ul class="post__tags-list">
            {post.data.tags.map((tag: string) => (
              <li class="post__tag">
                <a href={`/writing/tag/${tag}/`}>{tag}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </header>

    <DraftBanner growthStage={post.data.growthStage} />

    <Prose>
      <Content />
    </Prose>
  </article>

  <nav class="post-nav" aria-label="Post navigation">
    <div class="post-nav__item post-nav__prev">
      {prevPost && (
        <a href={`/writing/${prevPost.id}/`}>
          <span class="post-nav__label">&larr; Older</span>
          <span class="post-nav__title">{prevPost.data.title}</span>
        </a>
      )}
    </div>
    <div class="post-nav__item post-nav__next">
      {nextPost && (
        <a href={`/writing/${nextPost.id}/`}>
          <span class="post-nav__label">Newer &rarr;</span>
          <span class="post-nav__title">{nextPost.data.title}</span>
        </a>
      )}
    </div>
  </nav>
</BaseLayout>

<style>
  .post__header {
    margin-bottom: var(--space-8);
  }

  .post__header time {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .post__header h1 {
    font-size: clamp(2.5rem, 2rem + 1.8vw, 3.75rem);
    letter-spacing: -0.035em;
    margin-top: var(--space-2);
    margin-bottom: var(--space-3);
    /* Shared-element morph target — the clicked card title flows into this. */
    view-transition-name: post-title;
  }

  /* Keep prose body at a comfortable reading measure even though
     the surrounding container is wider for the headline. */
  .post :global(.prose) {
    max-width: var(--content-width);
  }

  .post__header,
  .post-nav {
    max-width: var(--wide-width);
  }

  .post__description {
    font-size: clamp(1.375rem, 1.25rem + 0.6vw, 1.5rem);
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-3);
  }

  /* Topic line — quiet editorial treatment, like a "Filed under" line in a magazine */
  .post__tags {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border-subtle);
  }

  .post__tags-label {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .post__tags-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .post__tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: 1;
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .post__tag a {
    color: var(--color-accent);
    text-decoration: none;
    font-variant-caps: all-small-caps;
    letter-spacing: 0.08em;
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .post__tag a:hover {
    color: var(--color-accent-hover);
  }

  /* Render the separator as a true mid-line dot, not the U+00B7 character
     which sits on the baseline under uppercase text. */
  .post__tag + .post__tag::before {
    content: "";
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-muted);
    opacity: 0.5;
    flex-shrink: 0;
  }

  /* Post Navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-subtle);
  }

  .post-nav__item a {
    text-decoration: none;
    display: block;
  }

  .post-nav__next {
    text-align: right;
  }

  .post-nav__label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.07em;
    margin-bottom: var(--space-1);
  }

  .post-nav__title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-accent);
    font-weight: 500;
  }

  .post-nav__item a:hover .post-nav__title {
    color: var(--color-accent-hover);
  }

  @media (max-width: 480px) {
    .post-nav {
      grid-template-columns: 1fr;
    }

    .post-nav__next {
      text-align: left;
    }
  }
</style>
