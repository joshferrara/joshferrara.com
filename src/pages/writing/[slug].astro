---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import DraftBanner from '../../components/DraftBanner.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: sorted[index + 1] ?? null,
      nextPost: sorted[index - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post">
    <header class="post__header">
      <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
      <h1>{post.data.title}</h1>
      {post.data.description && (
        <p class="post__description">{post.data.description}</p>
      )}
      {post.data.tags.length > 0 && (
        <div class="post__tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <DraftBanner growthStage={post.data.growthStage} />

    <Prose>
      <Content />
    </Prose>
  </article>

  <nav class="post-nav" aria-label="Post navigation">
    <div class="post-nav__item post-nav__prev">
      {prevPost && (
        <a href={`/writing/${prevPost.id}/`}>
          <span class="post-nav__label">&larr; Older</span>
          <span class="post-nav__title">{prevPost.data.title}</span>
        </a>
      )}
    </div>
    <div class="post-nav__item post-nav__next">
      {nextPost && (
        <a href={`/writing/${nextPost.id}/`}>
          <span class="post-nav__label">Newer &rarr;</span>
          <span class="post-nav__title">{nextPost.data.title}</span>
        </a>
      )}
    </div>
  </nav>
</BaseLayout>

<style>
  .post__header {
    margin-bottom: var(--space-8);
  }

  .post__header time {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .post__header h1 {
    font-size: var(--text-4xl);
    margin-top: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .post__description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }

  .post__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* Post Navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-subtle);
  }

  .post-nav__item a {
    text-decoration: none;
    display: block;
  }

  .post-nav__next {
    text-align: right;
  }

  .post-nav__label {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }

  .post-nav__title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-accent);
    font-weight: 500;
  }

  .post-nav__item a:hover .post-nav__title {
    color: var(--color-accent-hover);
  }

  @media (max-width: 480px) {
    .post-nav {
      grid-template-columns: 1fr;
    }

    .post-nav__next {
      text-align: left;
    }
  }
</style>
