---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import DraftBanner from '../../components/DraftBanner.astro';

export const prerender = true;

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const formattedDate = note.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={note.data.title}>
  <article class="note">
    <header class="note__header">
      <time datetime={note.data.date.toISOString()}>{formattedDate}</time>
      <h1>{note.data.title}</h1>
      {note.data.tags.length > 0 && (
        <div class="note__tags">
          {note.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <DraftBanner growthStage={note.data.growthStage} />

    <Prose>
      <Content />
    </Prose>
  </article>

  <div class="back-link">
    <a href="/notes/">&larr; All Notes</a>
  </div>
</BaseLayout>

<style>
  .note__header {
    margin-bottom: var(--space-6);
  }

  .note__header time {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .note__header h1 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .note__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .back-link {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-subtle);
    font-size: var(--text-sm);
  }
</style>
