---
interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  growthStage?: 'draft' | 'published';
  href: string;
  class?: string;
  readingTime?: number;
}

const { title, date, description, tags = [], growthStage = 'published', href, class: className, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class:list={['post-card', className]}>
  <a href={href} class="post-card__link">
    <div class="post-card__meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      {growthStage === 'draft' && <span class="badge badge--draft">Draft</span>}
    </div>
    {readingTime && (
      <span class="post-card__readtime" aria-hidden="true">{readingTime} min read</span>
    )}
    <h3 class="post-card__title">{title}</h3>
    {description && <p class="post-card__description">{description}</p>}
    {tags.length > 0 && (
      <div class="post-card__tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .post-card {
    border-bottom: 1px solid var(--color-border-subtle);
    padding: var(--space-5) 0;
  }

  .post-card:first-child {
    padding-top: 0;
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card__link {
    position: relative;
    text-decoration: none;
    color: inherit;
    display: block;
    padding: var(--space-3) var(--space-4);
    margin: calc(-1 * var(--space-3)) calc(-1 * var(--space-4));
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }

  /* Reading time: a quiet marginal note that surfaces on intent.
     Absolutely placed, so it never shifts the layout when it appears. */
  .post-card__readtime {
    position: absolute;
    top: var(--space-3);
    right: var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    font-variant-caps: all-small-caps;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(6px);
    transition: opacity var(--transition-base), transform var(--transition-base);
    pointer-events: none;
  }

  .post-card__link:hover .post-card__readtime,
  .post-card__link:focus-visible .post-card__readtime {
    opacity: 1;
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card__readtime {
      transition: opacity var(--transition-fast);
      transform: none;
    }
  }

  .post-card__link:hover {
    background: var(--color-bg-subtle);
  }

  .post-card__link:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .post-card__meta time {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
    font-variant-caps: all-small-caps;
    letter-spacing: 0.05em;
  }

  .post-card__title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-text-heading);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-1);
    letter-spacing: -0.025em;
    transition: color var(--transition-fast);
  }

  .post-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-2);
  }

  .post-card__tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
</style>
