---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const socials = [
  { label: 'X', href: 'https://x.com/joshferrara', icon: 'x' },
  { label: 'Instagram', href: 'https://instagram.com/joshferrara', icon: 'instagram' },
  { label: 'Threads', href: 'https://www.threads.net/@joshferrara', icon: 'threads' },
  { label: 'YouTube', href: 'https://youtube.com/joshferrara', icon: 'youtube' },
  { label: 'Flickr', href: 'https://flickr.com/joshferrara', icon: 'flickr' },
  { label: 'GitHub', href: 'https://github.com/joshferrara', icon: 'github' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/josh-ferrara', icon: 'linkedin' },
