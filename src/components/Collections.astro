---
import { getCollection } from 'astro:content';
import HomepageSection from './HomepageSection.astro';

// Counts are computed at build time and must match what each section's own
// index page displays, so the number never disagrees with the page behind the
// card. Placeholder entries (ids beginning with "_") are excluded everywhere;
// guides additionally exclude drafts (matching the guides index behavior).
function count(n: number, singular: string, plural: string): string {
  return `${n} ${n === 1 ? singular : plural}`;
}

const travel = (await getCollection('travel')).filter((e) => !e.id.startsWith('_'));
const guides = (await getCollection('guides')).filter(
  (e) => !e.id.startsWith('_') && e.data.growthStage !== 'draft'
);
const favorites = (await getCollection('favorites')).filter((e) => !e.id.startsWith('_'));
const recaps = await getCollection('recaps');
const latestRecapYear = recaps.length ? Math.max(...recaps.map((r) => r.data.year)) : null;

const items = [
  {
    title: 'Travel',
    href: '/travel/',
    description: 'City guides — where to eat, see & stay',
    meta: travel.length ? count(travel.length, 'city', 'cities') : null,
  },
  {
    title: 'Guides',
    href: '/guides/',
    description: 'Playbooks & how-tos',
    meta: guides.length ? count(guides.length, 'guide', 'guides') : null,
  },
  {
    title: 'Favorites',
    href: '/favorites/',
    description: 'Gear, tools & things I love',
    meta: favorites.length ? count(favorites.length, 'list', 'lists') : null,
  },
  {
    title: 'Annual Recaps',
    href: '/recaps/',
    description: 'My favorites from each year',
    meta: latestRecapYear ? `latest — ${latestRecapYear}` : null,
  },
];
---

<HomepageSection title="Collections">
  <ul class="collections" role="list">
    {items.map((item) => (
      <li class="collections__item">
        <a href={item.href} class="collection-row">
          <span class="collection-row__head">
            <span class="collection-row__title">{item.title}</span>
            {item.meta && <span class="collection-row__meta">{item.meta}</span>}
          </span>
          <span class="collection-row__desc">{item.description}</span>
        </a>
      </li>
    ))}
  </ul>
</HomepageSection>

<style>
  .collections {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .collections__item + .collections__item {
    border-top: 1px solid var(--color-border-subtle);
  }

  .collection-row {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-3) 0;
    color: inherit;
    text-decoration: none;
  }

  .collection-row__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .collection-row__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--text-base);
    letter-spacing: -0.01em;
    color: var(--color-text-heading);
    transition: color var(--transition-fast);
  }

  .collection-row:hover .collection-row__title {
    color: var(--color-accent);
  }

  .collection-row__meta {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .collection-row__desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
</style>
