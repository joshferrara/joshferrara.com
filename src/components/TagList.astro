---
interface Props {
  tags: string[];
  activeTag?: string;
  baseUrl?: string;
  /**
   * If provided, builds tag links as `${tagBaseUrl}${tag}/` (clean URLs)
   * instead of the legacy `?tag=...` query format.
   */
  tagBaseUrl?: string;
}

const { tags, activeTag, baseUrl, tagBaseUrl } = Astro.props;

function tagHref(tag: string) {
  if (tagBaseUrl) return `${tagBaseUrl}${encodeURIComponent(tag)}/`;
  if (baseUrl) return `${baseUrl}?tag=${encodeURIComponent(tag)}`;
  return '#';
}
---

{tags.length > 0 && (
  <div class="tag-list">
    {baseUrl && (
      <a
        href={baseUrl}
        class:list={['tag', { 'tag--active': !activeTag }]}
      >
        All
      </a>
    )}
    {tags.map((tag) => (
      <a
        href={tagHref(tag)}
        class:list={['tag', { 'tag--active': activeTag === tag }]}
      >
        {tag}
      </a>
    ))}
  </div>
)}

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .tag--active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .tag--active:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }
</style>
