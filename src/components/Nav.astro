---
const navLinks = [
  { href: '/writing/', label: 'Writing' },
  { href: '/projects/', label: 'Projects' },
  { href: '/now/', label: 'Now' },
  { href: '/about/', label: 'About' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="nav" aria-label="Primary">
  <div class="nav__inner container container--wide">
    <a href="/" class="nav__home">
      <span class="nav__monogram">JF</span>
      <span class="nav__identity" data-nav-logo>
        <img src="/images/josh.jpg" alt="" class="nav__photo" width="28" height="28" />
        <span class="nav__name">Josh Ferrara</span>
      </span>
    </a>
    <ul class="nav__links" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={['nav__link', { 'nav__link--active': isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const identity = document.querySelector('[data-nav-logo]');
  const monogram = document.querySelector('.nav__monogram');
  const bio = document.querySelector('.bio');

  if (identity && monogram && bio) {
    identity.classList.add('nav__identity--hidden');

    const observer = new IntersectionObserver(
      ([entry]) => {
        const heroVisible = entry.isIntersecting;
        identity.classList.toggle('nav__identity--hidden', heroVisible);
        monogram.classList.toggle('nav__monogram--hidden', !heroVisible);
      },
      { threshold: 0, rootMargin: '-64px 0px 0px 0px' }
    );

    observer.observe(bio);
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-subtle);
    height: var(--nav-height);
    display: flex;
    align-items: center;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__home {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-text-heading);
    position: relative;
    transition: color var(--transition-fast);
  }

  .nav__home:hover {
    color: var(--color-accent);
  }

  .nav__monogram {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.02em;
    transition: opacity var(--transition-base);
  }

  .nav__identity {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: -0.01em;
    transition: opacity var(--transition-base);
    position: absolute;
    left: 0;
    white-space: nowrap;
  }

  .nav__identity--hidden {
    opacity: 0;
    pointer-events: none;
  }

  .nav__identity--hidden + .nav__monogram,
  .nav__identity:not(.nav__identity--hidden) ~ .nav__monogram {
    /* handled by JS toggle below */
  }

  .nav__monogram.nav__monogram--hidden {
    opacity: 0;
    pointer-events: none;
  }

  .nav__photo {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    object-fit: cover;
  }

  .nav__links {
    display: flex;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
  }

  .nav__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    position: relative;
    transition: color var(--transition-fast);
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: var(--space-3);
    right: var(--space-3);
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    transform: scaleX(0);
    transition: transform var(--transition-base);
  }

  .nav__link:hover {
    color: var(--color-text-heading);
  }

  .nav__link:hover::after {
    transform: scaleX(1);
  }

  .nav__link--active {
    color: var(--color-accent);
  }

  .nav__link--active::after {
    transform: scaleX(1);
  }

  @media (max-width: 640px) {
    .nav__links {
      gap: 0;
    }

    .nav__link {
      padding: var(--space-2);
      font-size: var(--text-xs);
    }

    .nav__link::after {
      left: var(--space-2);
      right: var(--space-2);
    }
  }
</style>
