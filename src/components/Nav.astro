---
const navLinks = [
  { href: '/writing/', label: 'Writing' },
  { href: '/projects/', label: 'Projects' },
  { href: '/now/', label: 'Now' },
  { href: '/about/', label: 'About' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="nav" aria-label="Primary" transition:persist>
  <div class="nav__inner container container--wide">
    <a href="/" class="nav__home">
      <span class="nav__monogram">JF</span>
      <span class="nav__identity" data-nav-logo>
        <img src="/images/josh.jpg" alt="" class="nav__photo" width="28" height="28" />
        <span class="nav__name">Josh Ferrara</span>
      </span>
    </a>
    <div class="nav__right">
      <ul class="nav__links" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav__link', { 'nav__link--active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a class="nav__icon-btn" href="/search/" aria-label="Search" title="Search">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="M21 21l-4.3-4.3" />
        </svg>
      </a>

      <button class="nav__theme-toggle" type="button" aria-label="Switch color theme" title="Switch color theme">
        <svg class="nav__theme-icon nav__theme-icon--sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg class="nav__theme-icon nav__theme-icon--moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<script>
  // The nav is persisted across View Transitions (transition:persist), so it
  // never re-renders. We re-sync its state on every page load / swap instead.
  let heroObserver: IntersectionObserver | undefined;

  function updateActiveLink() {
    const path = window.location.pathname;
    document.querySelectorAll('.nav__link').forEach((link) => {
      const href = link.getAttribute('href') || '';
      const active = href === '/' ? path === '/' : path.startsWith(href);
      link.classList.toggle('nav__link--active', active);
      if (active) link.setAttribute('aria-current', 'page');
      else link.removeAttribute('aria-current');
    });
  }

  function setupHeroReveal() {
    const identity = document.querySelector('[data-nav-logo]');
    const monogram = document.querySelector('.nav__monogram');

    heroObserver?.disconnect();
    if (!identity || !monogram) return;

    const bio = document.querySelector('.bio');
    if (!bio) {
      // Inner pages have no hero: show the full identity, hide the monogram.
      identity.classList.remove('nav__identity--hidden');
      monogram.classList.add('nav__monogram--hidden');
      return;
    }

    // Home: start on the monogram (hero in view), reveal the identity on scroll.
    identity.classList.add('nav__identity--hidden');
    monogram.classList.remove('nav__monogram--hidden');

    heroObserver = new IntersectionObserver(
      ([entry]) => {
        const heroVisible = entry.isIntersecting;
        identity.classList.toggle('nav__identity--hidden', heroVisible);
        monogram.classList.toggle('nav__monogram--hidden', !heroVisible);
      },
      { threshold: 0, rootMargin: '-64px 0px 0px 0px' }
    );
    heroObserver.observe(bio);
  }

  function initNav() {
    updateActiveLink();
    setupHeroReveal();
  }

  document.addEventListener('astro:page-load', initNav);
  document.addEventListener('astro:after-swap', initNav);

  // ── Theme toggle ──────────────────────────────────────────────────────
  const root = document.documentElement;

  function effectiveTheme() {
    const explicit = root.dataset.theme;
    if (explicit === 'light' || explicit === 'dark') return explicit;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyStoredTheme() {
    try {
      const t = localStorage.getItem('theme');
      if (t === 'light' || t === 'dark') root.dataset.theme = t;
      else delete root.dataset.theme;
    } catch (e) {}
  }

  function toggleTheme() {
    const next = effectiveTheme() === 'dark' ? 'light' : 'dark';
    try { localStorage.setItem('theme', next); } catch (e) {}

    const apply = () => { root.dataset.theme = next; };
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (document.startViewTransition && !reduce) {
      root.classList.add('theme-vt');
      const vt = document.startViewTransition(apply);
      vt.finished.finally(() => root.classList.remove('theme-vt'));
    } else {
      apply();
    }
  }

  // Delegated so it keeps working with the persisted nav across navigations.
  document.addEventListener('click', (event) => {
    const target = event.target as Element | null;
    if (target?.closest?.('.nav__theme-toggle')) toggleTheme();
  });

  // Astro syncs <html> attributes to the incoming page on swap, which would
  // drop our data-theme — restore it before the new page paints.
  document.addEventListener('astro:after-swap', applyStoredTheme);
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-subtle);
    height: var(--nav-height);
    display: flex;
    align-items: center;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__home {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-text-heading);
    position: relative;
    transition: color var(--transition-fast);
  }

  .nav__home:hover {
    color: var(--color-accent);
  }

  .nav__monogram {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.02em;
    transition: opacity var(--transition-base);
  }

  .nav__identity {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: -0.01em;
    transition: opacity var(--transition-base);
    position: absolute;
    left: 0;
    white-space: nowrap;
  }

  .nav__identity--hidden {
    opacity: 0;
    pointer-events: none;
  }

  .nav__identity--hidden + .nav__monogram,
  .nav__identity:not(.nav__identity--hidden) ~ .nav__monogram {
    /* handled by JS toggle below */
  }

  .nav__monogram.nav__monogram--hidden {
    opacity: 0;
    pointer-events: none;
  }

  .nav__photo {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    object-fit: cover;
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav__links {
    display: flex;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
  }

  .nav__theme-toggle,
  .nav__icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav__theme-toggle { margin-left: var(--space-1); }

  .nav__theme-toggle:hover,
  .nav__icon-btn:hover {
    color: var(--color-accent);
    background: var(--color-bg-subtle);
  }

  .nav__theme-toggle:focus-visible,
  .nav__icon-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Which sun/moon icon shows is theme-dependent — see global.css.
     (Kept out of this scoped block so the global rules aren't outranked.) */

  .nav__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    position: relative;
    transition: color var(--transition-fast);
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: var(--space-3);
    right: var(--space-3);
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
    transform: scaleX(0);
    transition: transform var(--transition-base);
  }

  .nav__link:hover {
    color: var(--color-text-heading);
  }

  .nav__link:hover::after {
    transform: scaleX(1);
  }

  .nav__link--active {
    color: var(--color-accent);
  }

  .nav__link--active::after {
    transform: scaleX(1);
  }

  @media (max-width: 640px) {
    .nav__links {
      gap: 0;
    }

    .nav__link {
      padding: var(--space-2);
      font-size: var(--text-xs);
    }

    .nav__link::after {
      left: var(--space-2);
      right: var(--space-2);
    }
  }
</style>
