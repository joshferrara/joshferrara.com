---
interface Props {
  title: string;
  defaultOpen?: boolean;
}

const { title, defaultOpen = false } = Astro.props;
---

<details class="accordion" open={defaultOpen || undefined}>
  <summary class="accordion__trigger">
    <span class="accordion__title">{title}</span>
    <svg class="accordion__icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </summary>
  <div class="accordion__content">
    <slot />
  </div>
</details>

<style>
  /* Editorial disclosure: hairline-separated category sections, not boxed
     cards. The title is set in the display serif so the recap reads like a
     magazine's table of contents. */
  .accordion {
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .accordion:first-of-type {
    border-top: 1px solid var(--color-border-subtle);
  }

  .accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) 0;
    cursor: pointer;
    list-style: none;
    background: transparent;
    user-select: none;
  }

  .accordion__trigger::-webkit-details-marker {
    display: none;
  }

  .accordion__title {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-text-heading);
    transition: color var(--transition-fast);
  }

  .accordion__trigger:hover .accordion__title {
    color: var(--color-accent);
  }

  .accordion__icon {
    color: var(--color-text-muted);
    transition: transform var(--transition-base), color var(--transition-fast);
    flex-shrink: 0;
  }

  .accordion__trigger:hover .accordion__icon {
    color: var(--color-accent);
  }

  .accordion[open] .accordion__icon {
    transform: rotate(180deg);
  }

  .accordion__content {
    padding: var(--space-1) 0 var(--space-8);
  }

  /* The first heading inside an open section sits right under the trigger —
     pull its top margin so the spacing stays even. */
  .accordion__content :global(> :first-child) {
    margin-top: 0;
  }

  /* Style nested content */
  .accordion__content :global(p) {
    margin-bottom: var(--space-3);
  }

  .accordion__content :global(p:last-child) {
    margin-bottom: 0;
  }

  .accordion__content :global(ul),
  .accordion__content :global(ol) {
    margin-bottom: var(--space-3);
  }

  .accordion__content :global(img) {
    border-radius: var(--radius-sm);
    margin: var(--space-3) 0;
  }
</style>
