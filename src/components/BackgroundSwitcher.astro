---
const options = [
  { id: 'vignette', label: 'Vignette' },
  { id: 'dots', label: 'Dots' },
  { id: 'lines', label: 'Lines' },
  { id: 'grain', label: 'Grain' },
];
---

<div class="bg-switcher" data-bg-switcher>
  <button type="button" class="bg-switcher__toggle" aria-expanded="false" aria-controls="bg-switcher-panel" aria-label="Change background">
    <span class="bg-switcher__dot" aria-hidden="true"></span>
    <span class="bg-switcher__label" data-bg-current>Vignette</span>
  </button>
  <div id="bg-switcher-panel" class="bg-switcher__panel" hidden>
    <p class="bg-switcher__title">Background</p>
    {options.map((opt) => (
      <button
        type="button"
        class="bg-switcher__option"
        data-bg-option={opt.id}
        aria-pressed="false"
      >
        <span class={`bg-switcher__swatch bg-switcher__swatch--${opt.id}`} aria-hidden="true"></span>
        <span>{opt.label}</span>
      </button>
    ))}
  </div>
</div>

<style>
  .bg-switcher {
    position: fixed;
    bottom: var(--space-5);
    right: var(--space-5);
    z-index: 50;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
  }

  .bg-switcher__toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    color: var(--color-text-muted);
    cursor: pointer;
    box-shadow: var(--shadow-md);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .bg-switcher__toggle:hover {
    color: var(--color-text-heading);
    border-color: var(--color-accent-muted);
    transform: translateY(-1px);
  }

  .bg-switcher__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .bg-switcher__panel {
    position: absolute;
    bottom: calc(100% + var(--space-2));
    right: 0;
    min-width: 200px;
    padding: var(--space-3);
    background: var(--color-bg-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .bg-switcher__panel[hidden] {
    display: none;
  }

  .bg-switcher__title {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    padding: var(--space-1) var(--space-2) var(--space-2);
    margin: 0;
  }

  .bg-switcher__option {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text);
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    cursor: pointer;
    text-align: left;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }

  .bg-switcher__option:hover {
    background: var(--color-bg-subtle);
  }

  .bg-switcher__option[aria-pressed='true'] {
    background: var(--color-accent-bg);
    border-color: var(--color-accent-muted);
    color: var(--color-text-heading);
    font-weight: 600;
  }

  .bg-switcher__swatch {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background-color: var(--color-bg);
    flex-shrink: 0;
  }

  .bg-switcher__swatch--vignette {
    background-image:
      radial-gradient(ellipse 100% 80% at 100% 0%, var(--bg-vignette-warm) 0%, transparent 70%),
      radial-gradient(ellipse 100% 80% at 0% 100%, var(--bg-vignette-cool) 0%, transparent 70%);
  }

  .bg-switcher__swatch--dots {
    background-image: radial-gradient(circle, var(--color-dot-grid) 0.8px, transparent 0.8px);
    background-size: 8px 8px;
    background-position: 4px 4px;
  }

  .bg-switcher__swatch--lines {
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 5px,
      var(--color-rule) 5px,
      var(--color-rule) 6px
    );
  }

  .bg-switcher__swatch--grain {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='40' height='40'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='1.4' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.45 0 0 0 0 0.42 0 0 0 0 0.38 0 0 0 0.7 0'/></filter><rect width='40' height='40' filter='url(%23n)' opacity='0.6'/></svg>");
  }

  @media (max-width: 640px) {
    .bg-switcher {
      bottom: var(--space-3);
      right: var(--space-3);
    }
  }
</style>

<script>
  const STORAGE_KEY = 'bg-variant';
  const DEFAULT = 'vignette';
  const VALID = ['vignette', 'dots', 'lines', 'grain'];

  function getStored(): string {
    try {
      const v = localStorage.getItem(STORAGE_KEY);
      return v && VALID.includes(v) ? v : DEFAULT;
    } catch {
      return DEFAULT;
    }
  }

  function apply(variant: string) {
    document.documentElement.setAttribute('data-bg', variant);
    try {
      localStorage.setItem(STORAGE_KEY, variant);
    } catch {}

    const labelEl = document.querySelector<HTMLElement>('[data-bg-current]');
    if (labelEl) {
      labelEl.textContent = variant.charAt(0).toUpperCase() + variant.slice(1);
    }

    document.querySelectorAll<HTMLButtonElement>('[data-bg-option]').forEach((btn) => {
      btn.setAttribute('aria-pressed', btn.dataset.bgOption === variant ? 'true' : 'false');
    });
  }

  function init() {
    const root = document.querySelector<HTMLElement>('[data-bg-switcher]');
    if (!root) return;

    apply(getStored());

    const toggle = root.querySelector<HTMLButtonElement>('.bg-switcher__toggle');
    const panel = root.querySelector<HTMLElement>('.bg-switcher__panel');
    if (!toggle || !panel) return;

    toggle.addEventListener('click', () => {
      const open = !panel.hasAttribute('hidden');
      if (open) {
        panel.setAttribute('hidden', '');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        panel.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });

    root.querySelectorAll<HTMLButtonElement>('[data-bg-option]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const variant = btn.dataset.bgOption;
        if (variant) apply(variant);
      });
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) {
        panel.setAttribute('hidden', '');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
